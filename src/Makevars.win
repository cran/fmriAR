# CXX_STD = CXX11  # C++11 is required for auto keyword and range-based for loops
# Uncomment to enable OpenMP on supported toolchains
# PKG_CXXFLAGS += -fopenmp
# PKG_LIBS += -fopenmp

# Ensure Armadillo links against R's BLAS/LAPACK libraries on Windows
PKG_LIBS = $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS)

# Request the current Armadillo API to avoid fallback compilation notes
PKG_CPPFLAGS = -DARMA_USE_CURRENT
